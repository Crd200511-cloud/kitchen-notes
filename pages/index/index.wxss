.page {
  padding: 28rpx 24rpx 40rpx;
}

.hero {
  padding: 20rpx 8rpx 28rpx;
}

.hero__tag {
  display: inline-block;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #ffe2c7;
  color: #a45018;
  font-size: 22rpx;
  letter-spacing: 1rpx;
}

.hero__title {
  display: block;
  margin-top: 20rpx;
  font-size: 50rpx;
  line-height: 1.25;
  font-weight: 700;
  color: #2f241f;
}

.hero__desc {
  display: block;
  margin-top: 16rpx;
  font-size: 28rpx;
  line-height: 1.7;
  color: #7d6350;
}

.panel {
  margin-top: 24rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.82);
  box-shadow: 0 16rpx 40rpx rgba(111, 71, 31, 0.08);
  backdrop-filter: blur(12rpx);
}

.panel__head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 28rpx;
}

.panel__title {
  font-size: 34rpx;
  font-weight: 700;
  color: #2f241f;
}

.panel__tip {
  font-size: 24rpx;
  color: #997a64;
}

.field + .field {
  margin-top: 24rpx;
}

.field__label {
  display: block;
  margin-bottom: 14rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #5b4434;
}

.field__input,
.field__textarea {
  width: 100%;
  padding: 24rpx;
  border: 2rpx solid #f1dcc8;
  border-radius: 22rpx;
  background: #fffdf9;
  font-size: 28rpx;
  color: #2f241f;
}

.field__textarea {
  min-height: 200rpx;
}

.field__textarea--steps {
  min-height: 260rpx;
}

.actions {
  display: flex;
  gap: 18rpx;
  margin-top: 28rpx;
}

.button {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.button::after {
  border: 0;
}

.button--primary {
  background: linear-gradient(135deg, #e28b3e 0%, #cf5f25 100%);
  color: #ffffff;
}

.button--ghost {
  background: #fff4e8;
  color: #9a582b;
}

.empty {
  padding: 42rpx 20rpx;
  border-radius: 24rpx;
  background: #fff7ef;
  text-align: center;
}

.empty__title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #5f4838;
}

.empty__desc {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #9b7e68;
}

.recipe-card + .recipe-card {
  margin-top: 22rpx;
}

.recipe-card {
  padding: 24rpx;
  border-radius: 24rpx;
  background: #fffaf4;
}

.recipe-card__head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.recipe-card__title {
  flex: 1;
  font-size: 34rpx;
  font-weight: 700;
  color: #34261e;
}

.recipe-card__actions {
  display: flex;
  gap: 18rpx;
}

.recipe-card__action {
  font-size: 24rpx;
  color: #ad6534;
}

.recipe-card__action--danger {
  color: #c25545;
}

.section {
  margin-top: 24rpx;
}

.section__title {
  display: block;
  margin-bottom: 14rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #6d4f38;
}

.line-item,
.step-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.line-item + .line-item,
.step-item + .step-item {
  margin-top: 12rpx;
}

.line-item__dot {
  width: 12rpx;
  height: 12rpx;
  margin-top: 12rpx;
  border-radius: 50%;
  background: #e28b3e;
}

.line-item__text,
.step-item__text {
  flex: 1;
  font-size: 27rpx;
  line-height: 1.7;
  color: #4b382c;
}

.step-item__index {
  width: 38rpx;
  height: 38rpx;
  line-height: 38rpx;
  border-radius: 50%;
  background: #ffe2c8;
  color: #b25d21;
  font-size: 24rpx;
  font-weight: 700;
  text-align: center;
}
